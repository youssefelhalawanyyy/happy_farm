rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function userRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isSignedIn() && userRole() == 'admin';
    }

    function isManagerOrAdmin() {
      return isSignedIn() && (userRole() == 'admin' || userRole() == 'manager');
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isAdmin() || request.auth.uid == userId;
      allow update, delete: if isAdmin();
    }

    match /alerts/{alertId} {
      allow read: if isSignedIn();
      allow create: if isManagerOrAdmin();
      allow update: if isSignedIn();
      allow delete: if isAdmin();
    }

    match /batches/{docId} {
      allow read: if isSignedIn();
      allow create, update: if isManagerOrAdmin();
      allow delete: if isAdmin();
    }

    match /feedRecords/{docId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isManagerOrAdmin();
    }

    match /growthRecords/{docId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isManagerOrAdmin();
    }

    match /mortalityRecords/{docId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isManagerOrAdmin();
    }

    match /environmentReadings/{docId} {
      allow read: if isSignedIn();
      allow create: if true;
      allow update, delete: if isManagerOrAdmin();
    }

    match /marketPrices/{docId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isAdmin();
    }

    match /sales/{docId} {
      allow read: if isSignedIn();
      allow create, update: if isManagerOrAdmin();
      allow delete: if isAdmin();
    }

    match /expenses/{docId} {
      allow read: if isSignedIn();
      allow create, update: if isManagerOrAdmin();
      allow delete: if isAdmin();
    }

    match /inventory/{docId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isManagerOrAdmin();
    }

    match /livestockAdjustments/{docId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isManagerOrAdmin();
    }

    match /workers/{docId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isManagerOrAdmin();
    }

    match /tasks/{docId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isManagerOrAdmin();
    }

    match /quotations/{docId} {
      allow read: if isSignedIn();
      allow create, update: if isManagerOrAdmin();
      allow delete: if isAdmin();
    }

    match /notificationTokens/{docId} {
      allow read: if isAdmin();
      allow create, update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
